# Application
APP_NAME=Splitlah
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=base64:GenerateWithPhpArtisanKeyGenerate

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (Docker)
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=splitlah
DB_USERNAME=splitlah
DB_PASSWORD=your_database_password_here
DB_ROOT_PASSWORD=your_root_password_here

# Docker service ports (dev-only)
NGINX_PORT=8000
PMA_PORT=8080
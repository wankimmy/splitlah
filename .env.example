# APP_DEBUG must be false in production
APP_DEBUG=false
APP_ENV=production
# LOG_LEVEL must be info or higher in production
LOG_LEVEL=info
# SENSITIVE: Do NOT commit .env with real values
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=splitlah
DB_USERNAME=splitlah
DB_PASSWORD=your_database_password_here
APP_KEY=your_application_key_here